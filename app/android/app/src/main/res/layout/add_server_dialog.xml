<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <EditText android:id="@+id/add_server_dialog_server_name"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/add_server_dialog_field"
        android:hint="@string/add_server_dialog_server_name_hint"
        />

    <LinearLayout android:id="@+id/add_server_dialog_url_box"
        style="@style/add_server_dialog_field"
        app:layout_constraintTop_toBottomOf="@id/add_server_dialog_server_name"
        android:orientation="horizontal"
        >

        <EditText android:id="@+id/add_server_dialog_server_base_uri"
            android:layout_height="wrap_content"
            android:layout_width="0dp"
            android:layout_weight="80"
            android:hint="@string/add_server_dialog_server_base_uri_hint"
            android:inputType="textUri"
            />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="20"
            android:layout_height="wrap_content"
            android:gravity="center"
            >
            <br.com.simplepass.loadingbutton.customViews.CircularProgressButton
                android:id="@+id/add_server_dialog_test_connection"
                style="@style/connection_test_button"
                android:layout_width="wrap_content"
                app:spinning_bar_width="4dp"
                app:spinning_bar_color="@color/white"
                app:spinning_bar_padding="0dp"
                app:finalCornerAngle="50dp"
                />
        </LinearLayout>
    </LinearLayout>

    <CheckBox android:id="@+id/add_server_dialog_remember_login"
        app:layout_constraintTop_toBottomOf="@id/add_server_dialog_url_box"
        style="@style/add_server_dialog_field"
        android:text="@string/add_server_dialog_remember_login"
        android:checked="true"
        />

    <EditText android:id="@+id/add_server_dialog_login"
        app:layout_constraintTop_toBottomOf="@id/add_server_dialog_remember_login"
        style="@style/add_server_dialog_field"
        android:hint="@string/add_server_dialog_login_hint"
        />


    <CheckBox android:id="@+id/add_server_dialog_remember_password"
        app:layout_constraintTop_toBottomOf="@id/add_server_dialog_login"
        style="@style/add_server_dialog_field"
        android:text="@string/add_server_dialog_remember_password"
        android:checked="true"
        />

    <EditText android:id="@+id/add_server_dialog_password"
        app:layout_constraintTop_toBottomOf="@id/add_server_dialog_remember_password"
        style="@style/add_server_dialog_field"
        android:hint="@string/add_server_dialog_password"
        android:inputType="textPassword"
        />


</androidx.constraintlayout.widget.ConstraintLayout>