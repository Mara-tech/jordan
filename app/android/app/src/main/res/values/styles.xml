<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="action_button" parent="@style/Widget.AppCompat.Button.Colored">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:text">ACTION</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:layout_margin">@dimen/text_margin</item>
    </style>

    <style name="connection_test_button" parent="@style/Widget.AppCompat.Button.Colored">
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:text">@string/add_server_dialog_test</item>
    </style>

    <style name="generic_information_query_button" parent="@style/Widget.AppCompat.Button.Colored">
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:text">@string/generic_information_query_button</item>
    </style>

    <style name="dialog_title">
        <item name="android:textSize">@dimen/dialog_title_size</item>
        <item name="android:padding">13dp</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="dialog_multi_selection_item">
        <item name="android:textSize">@dimen/dialog_element_size</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:layout_marginStart">20dp</item>
    </style>

    <style name="add_server_dialog_field">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="layout_constraintStart_toStartOf">parent</item>
        <item name="layout_constraintEnd_toEndOf">parent</item>
        <item name="android:layout_margin">12dp</item>
        <item name="android:layout_marginStart">25dp</item>
    </style>
</resources>