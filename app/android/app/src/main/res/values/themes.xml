<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.JordanApp" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/red_bull</item>
        <item name="colorPrimaryDark">@color/bordeaux</item>
        <item name="colorAccent">@color/bordeaux</item>
        <item name="colorSurface">@color/light_grey</item>
        <item name="colorOnSurface">@color/grey</item>

        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.JordanApp.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.JordanApp.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.JordanApp.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>